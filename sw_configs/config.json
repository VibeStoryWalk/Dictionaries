{
  "appStorageKey": "urban-story-walks-v1",
  "showDebugSettings": true,
  "useLocalDicts": true,
  "dictionariesRepo": {
    "owner": "VibeStoryWalk",
    "name": "Dictionaries",
    "branch": "refs/heads/main"
  },
  "defaultUiSettings": {
    "locale": "pl",
    "textScale": 1,
    "simulationEnabled": false,
    "simulationSpeedKmh": 120,
    "adsEnabled": true,
    "autoSpeechEnabled": true,
    "ttsRate": 1,
    "ttsPitch": 1,
    "ttsVolume": 1,
    "ttsMusicFadeSeconds": 0.6
  },
  "textScaleSteps": [
    0.94,
    1,
    1.12,
    1.24
  ],
  "geolocationWatchOptions": {
    "enableHighAccuracy": true,
    "maximumAge": 5000,
    "timeout": 10000
  },
  "movingHumanRadiusMeters": 7,
  "osmTileUrl": "https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png",
  "osmAttribution": "&copy; OpenStreetMap contributors"
}
